# JWT Secret Configuration
# IMPORTANT: Generate a strong random string with at least 32 characters
# Generate command (Git Bash/WSL): openssl rand -base64 64
# Generate command (PowerShell): Run .\generate-jwt-secret.ps1
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-at-least-32-chars

# Add other environment variables here
# DB_PASSWORD=your-database-password
# API_KEY=your-api-key
